# API key and base URL are injected by bridge-server via env vars at spawn time.
# Do NOT set ANTHROPIC_API_KEY or ANTHROPIC_BASE_URL here — they are always
# provided by bridge-server (proxy URL for self-hosted, gateway for Clawparrot).
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
API_TIMEOUT_MS=300000
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# Disable extended thinking entirely. This is a tool-use agent, not a chat-only
# reasoning assistant — opus 4.x's adaptive thinking mode causes a pathology
# where the model writes the entire solution (HTML/JS/code) inside thinking
# blocks then ends the turn with empty output and zero tool calls. See
# claude.ts:1604 for the adaptive injection logic.
# TEMPORARILY DISABLED 2026-04-17: testing whether this flag is what breaks
# opus tool-use when upstream forces thinking mode (e.g. Vertex-only thinking
# variant via Antigravity relay). If removing it fixes opus agent tasks, the
# real bug is in how engine SSE handler processes thinking blocks when we told
# it thinking is disabled — a code path not covered by the vendored patches.
# CLAUDE_CODE_DISABLE_THINKING=1
